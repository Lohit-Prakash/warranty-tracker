# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Client URL (Vercel deployment URL — used for CORS) ────────────────────────
# Set this to your Vercel URL after deploying the frontend
# e.g. https://warrantyvault.vercel.app
CLIENT_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# On Railway: mount a Volume at /data and set DB_PATH=/data/warrantyvault.db
# This ensures the SQLite file survives redeployments
DB_PATH=./warrantyvault.db

# ── Uploads ───────────────────────────────────────────────────────────────────
# On Railway: mount a Volume at /data and set UPLOADS_DIR=/data/uploads
# Google-authenticated users use Google Drive (no local disk needed for them)
UPLOADS_DIR=./uploads

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string

# ── SMTP / Email (for warranty expiry notifications) ─────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# ── Google OAuth + Drive ──────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Redirect URI must be: https://your-backend.up.railway.app/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-backend.up.railway.app/api/auth/google/callback

# 64-char hex key for encrypting Google refresh tokens at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GOOGLE_TOKEN_ENCRYPTION_KEY=

# Random string for CSRF protection on OAuth callback
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
OAUTH_STATE_SECRET=
