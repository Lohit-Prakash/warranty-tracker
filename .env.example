# Server Configuration
PORT=3001
NODE_ENV=development

# JWT Secret (change this to a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database (SQLite path for development)
DB_PATH=./purchasevault.db

# SMTP Email Configuration (for warranty expiration notifications)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=7a97c9961ee3d9
SMTP_PASS=85c01033f74c4b

# Email sender details
EMAIL_FROM_NAME=PurchaseVault
EMAIL_FROM_ADDRESS=your-email@gmail.com

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# File upload settings
MAX_FILE_SIZE_MB=5
UPLOADS_DIR=./uploads


GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=replace-with-64-char-hex-string
OAUTH_STATE_SECRET=replace-with-random-secret-string

# Razorpay (get from razorpay.com dashboard)
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxx
RAZORPAY_PLAN_ID_PRO_MONTHLY=plan_xxxx
RAZORPAY_PLAN_ID_PRO_YEARLY=plan_xxxx
RAZORPAY_PLAN_ID_BUSINESS_MONTHLY=plan_xxxx
RAZORPAY_PLAN_ID_BUSINESS_YEARLY=plan_xxxx