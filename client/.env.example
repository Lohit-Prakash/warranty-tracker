# Razorpay public key (safe to expose in frontend — use TEST key for development)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxx

# Razorpay plan IDs (copy from Razorpay Dashboard → Subscriptions → Plans)
VITE_RAZORPAY_PLAN_ID_PRO_MONTHLY=plan_xxxx
VITE_RAZORPAY_PLAN_ID_PRO_YEARLY=plan_xxxx
VITE_RAZORPAY_PLAN_ID_BUSINESS_MONTHLY=plan_xxxx
VITE_RAZORPAY_PLAN_ID_BUSINESS_YEARLY=plan_xxxx
